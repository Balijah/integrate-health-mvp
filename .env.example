# ===========================================
# Integrate Health MVP - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ===========================================
# Application Settings
# ===========================================
ENVIRONMENT=development
DEBUG=true

# Security (generate with: openssl rand -hex 32)
APP_SECRET_KEY=your-secret-key-min-32-chars-change-in-prod
JWT_SECRET_KEY=your-jwt-secret-key-min-32-chars

# ===========================================
# Database
# ===========================================
# Local Docker development
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/integrate_health

# AWS RDS (use this format for production)
# DATABASE_URL=postgresql+asyncpg://username:password@rds-endpoint:5432/integrate_health

# PostgreSQL container settings (for docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=integrate_health

# ===========================================
# Storage Mode
# ===========================================
# Options: "local" or "s3"
STORAGE_MODE=local

# Local storage directory (when STORAGE_MODE=local)
UPLOAD_DIR=uploads

# ===========================================
# AWS Configuration (required for production)
# ===========================================
AWS_REGION=us-east-1

# S3 bucket for audio storage (required when STORAGE_MODE=s3)
S3_BUCKET_NAME=

# S3 prefix for audio files
S3_AUDIO_PREFIX=audio/

# ===========================================
# Whisper Service (Self-hosted Transcription)
# ===========================================
# Local development (if running Whisper locally)
WHISPER_SERVICE_URL=http://localhost:8080

# AWS deployment (use internal IP from Terraform)
# WHISPER_SERVICE_URL=http://10.0.2.x:8080

# Timeout for transcription requests (seconds)
WHISPER_TIMEOUT_SECONDS=300

# ===========================================
# AWS Bedrock (LLM for Note Generation)
# ===========================================
# Model options:
# - anthropic.claude-3-sonnet-20240229-v1:0 (recommended)
# - anthropic.claude-3-haiku-20240307-v1:0 (faster, cheaper)
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# Generation parameters
BEDROCK_MAX_TOKENS=4096
BEDROCK_TEMPERATURE=0.3

# ===========================================
# Legacy External Services
# ===========================================
# These are optional and kept for backward compatibility
# They will be removed after full AWS migration

# Deepgram API (legacy transcription)
DEEPGRAM_API_KEY=

# Anthropic API (legacy LLM)
ANTHROPIC_API_KEY=

# ===========================================
# File Upload Settings
# ===========================================
MAX_AUDIO_SIZE_MB=100
ALLOWED_AUDIO_FORMATS=wav,mp3,m4a,webm,ogg
